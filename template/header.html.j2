<div class="notebook-header">
  <h1>{{ resources.notebook_meta.title }}</h1>
  <div class="meta">
    <div class="authors">
      <div class="author-avatars">
        {% for author in resources.notebook_meta.authors %}
        <img src="{{ author.avatar }}" alt="{{ author.name }}" class="author-avatar">
        {% endfor %}
      </div>
      <div class="author-info">
        <span class="author-names">
          {{ resources.notebook_meta.authors | map(attribute='name') | join(', ') }}
        </span>
        {% if resources.notebook_meta.date %}
        <span class="date">{{ resources.notebook_meta.date }}</span>
        {% endif %}
      </div>
    </div>
    {% if resources.notebook_meta.github_url %}
    <a href="{{ resources.notebook_meta.github_url }}" class="github-button" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link-icon lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <span>View on GitHub</span>
    </a>
    {% endif %}
  </div>
</div>
