<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Columnar Cookbook</title>
  <link rel="icon" type="image/x-icon" href="/favicon.svg">
  <link rel="stylesheet" href="style.css">
</head>
<body>
{% include 'components/navbar.html.j2' %}
<main>
  <div class="header">
    <h1>Columnar Cookbook</h1>
    <p>Guides and examples for working with columnar data and Arrow-native tools</p>
  </div>
  <table class="cookbooks">
    <thead>
      <tr>
        <th>Title</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
    {% for entry in registry|sort(attribute='date', reverse=true) %}
      <tr class="clickable-row" data-href="/{{ entry.path|replace('notebooks/', '')|replace('.ipynb', '') }}">
          <td>{{ entry.title }}</td>
          <td>{{ entry.date|format_date }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  <div class="contribution">
    <p>Got a great cookbook idea? We'd love to see your contribution!</p>
    <a href="https://github.com/columnar-tech/columnar-cookbook/blob/main/CONTRIBUTING.md" class="button" target="_blank" rel="noopener noreferrer">
      <span>Contribution guide</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-move-up-right-icon lucide-move-up-right"><path d="M13 5H19V11"/><path d="M19 5L5 19"/></svg>
    </a>
  </div>
</main>
  <script>
    document.querySelectorAll('.clickable-row').forEach(row => {
      row.addEventListener('click', () => {
        window.location.href = row.dataset.href;
      });
      row.style.cursor = 'pointer';
    });
  </script>
</body>
</html>
